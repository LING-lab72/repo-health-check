# DeepSeek API Key (primary, recommended)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# OpenAI API Key (fallback)
OPENAI_API_KEY=sk-your-openai-key-here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# GitHub clone proxy fallback (optional)
GIT_HTTP_PROXY=http://127.0.0.1:7890

# GitHub OAuth
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# Frontend URL (for OAuth redirect)
FRONTEND_URL=http://localhost:5174

# Session signing secret (change in production!)
SESSION_SECRET=your-random-secret-here

# Production security knobs
COOKIE_SECURE=false
TRUST_PROXY_HEADERS=false

# Allow npx to download analyzer tools at runtime (disabled by default)
ALLOW_NPX_INSTALL=0
